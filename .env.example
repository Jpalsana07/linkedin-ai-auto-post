# Which LLM provider to use for generation: openai | anthropic | gemini
LLM_PROVIDER=openai

# Default model IDs per provider. Override only if your account uses a different ID.
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash

# API keys — only the one for the chosen LLM_PROVIDER is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Behavior knobs
MAX_GENERATION_ATTEMPTS=3
TOPIC_COOLDOWN_DAYS=7
HISTORY_LOOKBACK=30
SIMILARITY_THRESHOLD=0.55

# Publishing — leave blank to draft-only (markdown saved to data/generated-posts/).
# To auto-post to LinkedIn:
#   1. Create a LinkedIn Developer App at https://developer.linkedin.com
#   2. Run `bun run auth:linkedin` — it prints the values to paste below.
# Required:  LINKEDIN_PERSON_URN + one of (LINKEDIN_ACCESS_TOKEN) or (LINKEDIN_CLIENT_ID + LINKEDIN_CLIENT_SECRET + LINKEDIN_REFRESH_TOKEN).
LINKEDIN_PERSON_URN=
LINKEDIN_ACCESS_TOKEN=

# Optional — required only if your app is approved for "Programmatic Refresh Tokens".
# When set, the cron mints a fresh access token on every run instead of relying on the 60-day static one.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=

# When true, skips file writes and commits. Useful for local testing.
DRY_RUN=false
